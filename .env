# .env - Environment Configuration
# Digital Platform - Threat Intelligence

# ============================================
# Database Configuration
# ============================================
DB_CONNECTION_STRING=Server=sqlserver;Database=ThreatIntelligence;User Id=sa;Password=P@ssw0rd1234;Encrypt=false;
DB_PASSWORD=P@ssw0rd1234

# ============================================
# Redis Configuration
# ============================================
REDIS_CONNECTION_STRING=redis:6379
REDIS_PASSWORD=

# ============================================
# RabbitMQ Configuration
# ============================================
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672

# ============================================
# Elasticsearch Configuration
# ============================================
ELASTICSEARCH_URL=http://elasticsearch:9200

# ============================================
# API Configuration
# ============================================
API_PORT=5000
API_HTTPS_PORT=5001
API_KEY=your-secret-api-key-here

# ============================================
# JWT Configuration
# ============================================
JWT_SECRET=your-super-secret-jwt-key-that-is-very-long-for-security-purposes-change-this-in-production
JWT_ISSUER=threat-intelligence-platform
JWT_AUDIENCE=threat-intelligence-api
JWT_EXPIRY_MINUTES=60

# ============================================
# Email Configuration
# ============================================
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your-email@gmail.com
EMAIL_SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@threat-intelligence.com

# ============================================
# SMS Configuration (Twilio)
# ============================================
TWILLIO_ACCOUNT_SID=your-twilio-account-sid
TWILLIO_AUTH_TOKEN=your-twilio-auth-token
TWILLIO_PHONE_NUMBER=+1234567890

# ============================================
# Slack Configuration
# ============================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_BOT_TOKEN=xoxb-your-bot-token

# ============================================
# Microsoft Teams Configuration
# ============================================
TEAMS_WEBHOOK_URL=https://outlook.webhook.office.com/webhookb2/

# ============================================
# External APIs
# ============================================
HAVEIBEEN_PWNED_API_KEY=your-api-key
SHODAN_API_KEY=your-api-key
GITHUB_API_TOKEN=your-github-token
BING_SEARCH_API_KEY=your-bing-key

# ============================================
# Application Configuration
# ============================================
APP_ENVIRONMENT=Development
APP_LOG_LEVEL=Debug
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000
APP_MAX_FILE_UPLOAD_SIZE=10485760

# ============================================
# Security
# ============================================
SECURE_COOKIES=false
ALLOW_ANONYMOUS_REGISTRATION=false
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# ============================================
# Scanning Configuration
# ============================================
SCAN_MAX_CONCURRENT_JOBS=5
SCAN_TIMEOUT_SECONDS=300
SCAN_RETRY_ATTEMPTS=3

# ============================================
# Feature Flags
# ============================================
FEATURE_DARK_WEB_SCANNING=true
FEATURE_AUTOMATED_ACTIONS=true
FEATURE_AI_THREAT_ANALYSIS=false
FEATURE_MOBILE_APP=false
